TABERU_MATE_APP_NAME="TaberuMate API"
TABERU_MATE_VERSION="0.1.0"
TABERU_MATE_ENVIRONMENT="local"
TABERU_MATE_DEBUG=false
TABERU_MATE_API_V1_PREFIX="/api/v1"
TABERU_MATE_ALLOWED_ORIGINS='["http://localhost:5173","http://127.0.0.1:5173"]'
TABERU_MATE_DATABASE_PATH="data/taberu_mate.db"
TABERU_MATE_AUTH_TOKEN_SECRET="replace-with-a-long-random-token-secret"
TABERU_MATE_ACCESS_TOKEN_EXPIRE_MINUTES=15
TABERU_MATE_REFRESH_TOKEN_EXPIRE_DAYS=30
TABERU_MATE_ACCESS_TOKEN_COOKIE_NAME="access_token"
TABERU_MATE_REFRESH_TOKEN_COOKIE_NAME="refresh_token"
TABERU_MATE_CSRF_COOKIE_NAME="csrf_token"
TABERU_MATE_CSRF_HEADER_NAME="X-CSRF-Token"
TABERU_MATE_AUTH_COOKIE_SECURE=true
TABERU_MATE_AUTH_COOKIE_SAMESITE="strict"
TABERU_MATE_AUTH_LOGIN_RATE_LIMIT=5
TABERU_MATE_AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
TABERU_MATE_SENTRY_DSN=""
